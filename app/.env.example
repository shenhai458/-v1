# ── Backend ─────────────────────────────────────────────────────
APP_SECRET=               # Application secret (used for JWT signing)

# ── Database (Turso / libSQL) ───────────────────────────────────
DATABASE_URL=             # Turso database URL (libsql://xxx.turso.io or file:./data/local.db)
DATABASE_AUTH_TOKEN=      # Turso auth token (leave empty for local SQLite)

# ── Environment ────────────────────────────────────────────────
NODE_ENV=production       # production | development
